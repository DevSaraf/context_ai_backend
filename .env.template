# ============================================================
# KRAB — Environment Variables
# Copy this to .env in your project root and fill in the values
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/krab

# --- JWT ---
SECRET_KEY=your-secret-key-here

# --- Google Gemini (for embeddings + LLM) ---
GOOGLE_API_KEY=your-gemini-api-key

# ============================================================
# CONNECTOR OAUTH CREDENTIALS
# 
# You need to create OAuth apps at each provider's developer portal.
# Only configure the ones you want to use — unconfigured connectors
# will show "OAuth not configured" when users click Connect.
# ============================================================

# --- Google Drive ---
# Create at: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (type: Web application)
# 2. Add authorized redirect URI: http://localhost:8000/connectors/oauth/callback
#    (and your production URL: https://krabai.tech/connectors/oauth/callback)
# 3. Enable Google Drive API in your project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Notion ---
# Create at: https://www.notion.so/my-integrations
# 1. Create a new integration (type: Public)
# 2. Set redirect URI: http://localhost:8000/connectors/oauth/callback
# 3. Copy the OAuth client ID and secret
NOTION_CLIENT_ID= 
NOTION_CLIENT_SECRET= 

# --- GitHub ---
# Create at: https://github.com/settings/developers
# 1. New OAuth App
# 2. Authorization callback URL: http://localhost:8000/connectors/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Slack ---
# Create at: https://api.slack.com/apps
# 1. Create New App > From scratch
# 2. OAuth & Permissions > Add redirect URL: http://localhost:8000/connectors/oauth/callback
# 3. Scopes: channels:read, channels:history, groups:read, groups:history, users:read
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# --- Confluence (Atlassian) ---
# Create at: https://developer.atlassian.com/console/myapps/
# 1. Create OAuth 2.0 app
# 2. Authorization > Add callback URL: http://localhost:8000/connectors/oauth/callback
# 3. Permissions: Confluence API > read:confluence-content.all, read:confluence-space.summary
CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=
